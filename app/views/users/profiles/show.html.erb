<div class="min-h-screen bg-gray-50 py-12 px-4 sm:px-6 lg:px-8">
  <div class="max-w-3xl mx-auto">
    <%= render 'shared/navigation' %>

    <% if flash[:alert] %>
      <div class="mb-4 p-4 text-sm text-red-700 bg-red-100 rounded-lg border border-red-200" role="alert">
        <%= flash[:alert] %>
      </div>
    <% end %>

    <% if flash[:notice] %>
      <div class="mb-4 p-4 text-sm text-green-700 bg-green-100 rounded-lg border border-green-200" role="alert">
        <%= flash[:notice] %>
      </div>
    <% end %>

    <div class="bg-white shadow overflow-hidden rounded-lg">
      <div class="px-4 py-5 sm:px-6 flex justify-between items-center">
        <div>
          <h2 class="text-2xl font-bold text-gray-900">Profile</h2>
          <p class="mt-1 text-sm text-gray-500">Your account information</p>
        </div>
        <%= link_to "Change Password", edit_user_registration_path,
            class: "inline-flex items-center px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
      </div>
      <div class="border-t border-gray-200">
        <dl>
          <div class="bg-gray-50 px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
            <dt class="text-sm font-medium text-gray-500">Name</dt>
            <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2"><%= current_user.name %></dd>
          </div>
          <div class="bg-white px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
            <dt class="text-sm font-medium text-gray-500">Email</dt>
            <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2"><%= current_user.email %></dd>
          </div>
          <div class="bg-gray-50 px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
            <dt class="text-sm font-medium text-gray-500">Member since</dt>
            <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2"><%= current_user.created_at.strftime("%B %d, %Y") %></dd>
          </div>
        </dl>
      </div>
    </div>

    <% if @balances.present? %>
      <div class="bg-white shadow overflow-hidden rounded-lg mt-6">
        <div class="px-4 py-5 sm:px-6 flex justify-between items-center">
          <div>
            <h2 class="text-2xl font-bold text-gray-900">Balances</h2>
            <p class="mt-1 text-sm text-gray-500">Outstanding balances with other users</p>
          </div>
          <%= link_to "Record Payment", new_financial_transaction_path,
              class: "inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
        </div>
        <div class="border-t border-gray-200">
          <ul class="divide-y divide-gray-200">
            <% @balances.each do |entry| %>
              <li class="px-4 py-4 sm:px-6 flex items-center justify-between">
                <div class="flex items-center space-x-3">
                  <div class="h-8 w-8 rounded-full bg-indigo-100 flex items-center justify-center">
                    <span class="text-indigo-700 text-sm font-medium"><%= entry[:user].name[0].upcase %></span>
                  </div>
                  <span class="text-sm font-medium text-gray-900"><%= entry[:user].name %></span>
                </div>
                <% if entry[:amount] > 0 %>
                  <span class="inline-flex px-3 py-1 text-sm font-medium rounded-full bg-red-100 text-red-800">
                    You owe <%= number_to_currency(entry[:amount], unit: "RSD ", precision: 2) %>
                  </span>
                <% else %>
                  <span class="inline-flex px-3 py-1 text-sm font-medium rounded-full bg-green-100 text-green-800">
                    Owes you <%= number_to_currency(-entry[:amount], unit: "RSD ", precision: 2) %>
                  </span>
                <% end %>
              </li>
            <% end %>
          </ul>
        </div>
      </div>
    <% else %>
      <div class="bg-white shadow overflow-hidden rounded-lg mt-6">
        <div class="px-4 py-5 sm:px-6 flex justify-between items-center">
          <div>
            <h2 class="text-2xl font-bold text-gray-900">Balances</h2>
            <p class="mt-1 text-sm text-gray-500">No outstanding balances</p>
          </div>
          <%= link_to "Record Payment", new_financial_transaction_path,
              class: "inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
        </div>
      </div>
    <% end %>
    <div class="bg-white shadow overflow-hidden rounded-lg mt-6">
      <div class="px-4 py-5 sm:px-6 flex justify-between items-center">
        <div>
          <h2 class="text-2xl font-bold text-gray-900">Recent Payments</h2>
          <p class="mt-1 text-sm text-gray-500">Last 10 peer-to-peer payments</p>
        </div>
        <div class="flex items-center space-x-3">
          <%= link_to "View All", financial_transactions_path,
              class: "inline-flex items-center px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50" %>
          <%= link_to "Record Payment", new_financial_transaction_path,
              class: "inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700" %>
        </div>
      </div>
      <% if @recent_payments.any? %>
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Date</th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">From</th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">To</th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Amount</th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Description</th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"></th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-200">
            <% @recent_payments.each do |ft| %>
              <tr>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= ft.created_at.strftime("%b %d, %H:%M") %></td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900"><%= ft.sender.name %></td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900"><%= ft.receiver.name %></td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900"><%= number_to_currency(ft.amount, unit: "RSD ", precision: 2) %></td>
                <td class="px-6 py-4 text-sm text-gray-500"><%= ft.description || "—" %></td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-right space-x-2">
                  <% if ft.sender_id == current_user.id %>
                    <%= link_to "Edit", edit_financial_transaction_path(ft),
                      class: "text-indigo-600 hover:text-indigo-900" %>
                    <%= link_to "Delete", financial_transaction_path(ft),
                      data: { "turbo-method": :delete, "turbo-confirm": "Delete this payment?" },
                      class: "text-red-600 hover:text-red-800" %>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% else %>
        <div class="px-6 py-4 text-sm text-gray-500">No payments recorded.</div>
      <% end %>
    </div>
  </div>
</div>
