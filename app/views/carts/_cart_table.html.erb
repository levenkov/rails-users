<div class="bg-white shadow rounded-lg overflow-hidden">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Article</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Price</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider w-28">Qty</th>
        <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Total</th>
      </tr>
    </thead>
    <tbody class="bg-white divide-y divide-gray-200">
      <% grouped_cart_items.each do |group| %>
        <% if grouped_cart_items.size > 1 %>
          <tr class="bg-gray-50">
            <td colspan="4" class="px-6 py-2 text-xs font-semibold text-gray-600 uppercase tracking-wider">
              <%= group[:user].id == current_user_id ? 'You' : group[:user].name %>
              <% if ready_user_ids.include?(group[:user].id) %>
                <span class="ml-2 inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-700">Ready</span>
              <% end %>
            </td>
          </tr>
        <% end %>
        <% group[:items].each do |item| %>
          <tr>
            <td class="px-6 py-4 whitespace-nowrap">
              <div class="flex items-center">
                <% if item[:article].photos.any? %>
                  <div class="w-10 h-10 flex-shrink-0 mr-3">
                    <%= image_tag item[:article].photos.first, class: "w-10 h-10 rounded object-cover" %>
                  </div>
                <% end %>
                <span class="text-sm font-medium text-gray-900"><%= item[:article].title %><% if item[:variant].name.present? %> — <%= item[:variant].name %><% end %></span>
              </div>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
              <%= number_to_currency(item[:variant].price, unit: "") %> RSD
            </td>
            <td class="px-6 py-4 whitespace-nowrap">
              <input type="number" name="quantities[<%= item[:id] %>]" value="<%= item[:quantity] %>" min="0" class="w-20 rounded-md border border-gray-300 px-2 py-1 text-sm text-gray-900 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500">
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 text-right">
              <%= number_to_currency(item[:line_total], unit: "") %> RSD
            </td>
          </tr>
        <% end %>
      <% end %>
    </tbody>
    <tfoot>
      <tr class="bg-gray-50">
        <td colspan="3" class="px-6 py-4 text-sm font-semibold text-gray-900 text-right">Total:</td>
        <td class="px-6 py-4 text-sm font-semibold text-gray-900 text-right"><%= number_to_currency(total, unit: "") %> RSD</td>
      </tr>
    </tfoot>
  </table>
</div>
