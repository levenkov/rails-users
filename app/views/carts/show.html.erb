<div class="min-h-screen bg-gray-50 py-8 px-4 sm:px-6 lg:px-8">
  <div class="max-w-3xl mx-auto">
    <%= render 'shared/navigation' %>

    <% unless @cart&.closed? %>
      <%= render 'shared/cart_selector', carts: @user_carts, selected_cart_id: @cart&.id %>
    <% end %>

    <% if @cart&.closed? %>
      <div class="bg-gray-100 border border-gray-300 rounded-md p-4 mb-6 flex items-center justify-between">
        <p class="text-sm text-gray-600">This cart was used to create an order and is now closed.</p>
        <%= link_to "Copy to new cart", copy_cart_path(@cart), data: { turbo_method: :post }, class: "py-2 px-4 rounded-md text-sm font-medium text-indigo-600 border border-indigo-300 hover:bg-indigo-50" %>
      </div>

      <% if @grouped_cart_items.any? %>
        <%= render partial: 'cart_table', locals: { grouped_cart_items: @grouped_cart_items, total: @total, current_user_id: current_user.id, ready_user_ids: @ready_user_ids } %>
      <% end %>

    <% elsif @cart && @grouped_cart_items.any? %>
      <%= form_with url: cart_path(@cart), method: :patch, local: true do %>
        <%= render partial: 'cart_table', locals: { grouped_cart_items: @grouped_cart_items, total: @total, current_user_id: current_user.id, ready_user_ids: @ready_user_ids } %>

        <div class="mt-3 flex justify-between items-center">
          <button type="submit" id="update-cart-btn" disabled class="py-2 px-4 rounded-md text-sm font-medium text-gray-700 border border-gray-300 hover:bg-gray-50 disabled:opacity-50 disabled:cursor-not-allowed">Update Cart</button>
          <%= link_to "Order something else", market_path(@cart.market, cart_id: @cart.id), class: "py-2 px-4 rounded-md text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700" %>
        </div>

        <%= content_tag :div, nil,
          id: "cart-participants-root",
          class: "mt-6",
          data: {
            participants: @participants.map { |u| { id: u.id, name: u.name } }.to_json,
            current_user_id: current_user.id,
            current_user_name: current_user.name,
            add_participant_path: add_participant_cart_path(@cart),
            remove_participant_path: remove_participant_cart_path(@cart),
            csrf_token: form_authenticity_token,
          } %>

        <% if @cart.owner_id == current_user.id %>
          <div class="mt-6 flex justify-between">
            <%= link_to "Delete Cart", cart_path(@cart), data: { turbo_method: :delete, turbo_confirm: "Delete Cart?" }, class: "py-2 px-4 rounded-md text-sm font-medium text-red-600 border border-red-300 hover:bg-red-50" %>
            <%= link_to "Checkout", checkout_orders_path(cart_id: @cart.id), class: "py-2 px-4 rounded-md text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700" %>
          </div>
        <% end %>
      <% end %>
      <% if @cart.cart_items.exists?(user: current_user) %>
        <div class="mt-3">
          <% if @ready_user_ids.include?(current_user.id) %>
            <%= button_to "Undo ready", toggle_ready_cart_path(@cart), class: "py-2 px-4 rounded-md text-sm font-medium text-green-700 border border-green-300 bg-green-50 hover:bg-green-100" %>
          <% else %>
            <%= button_to "I'm ready", toggle_ready_cart_path(@cart), class: "py-2 px-4 rounded-md text-sm font-medium text-gray-700 border border-gray-300 hover:bg-gray-50" %>
          <% end %>
        </div>
      <% end %>
      <script>
        (function() {
          var btn = document.getElementById('update-cart-btn');
          var inputs = document.querySelectorAll('input[name^="quantities["]');
          var originals = {};
          inputs.forEach(function(input) { originals[input.name] = input.value; });
          function check() {
            var changed = false;
            inputs.forEach(function(input) {
              if (input.value !== originals[input.name]) changed = true;
            });
            btn.disabled = !changed;
          }
          inputs.forEach(function(input) { input.addEventListener('input', check); });
        })();
      </script>
    <% else %>
      <div class="text-center py-20">
        <p class="text-lg text-gray-500 mb-4">Your cart is empty</p>
        <%= link_to "Browse Markets", root_path, class: "text-indigo-600 hover:text-indigo-900 font-medium" %>
      </div>
    <% end %>
  </div>
</div>
