<div class="py-6 px-8" style="max-width: 1200px;">
  <div class="mb-6">
    <%= link_to "← Back to Orders", admin_orders_path, class: "text-indigo-600 hover:text-indigo-900 text-sm" %>
  </div>

  <div class="mb-8 flex items-center justify-between">
    <div class="flex items-center space-x-4">
      <h1 class="text-3xl font-bold text-gray-900">Order #<%= @order.id %></h1>
      <% state_colors = { 'submitted' => 'yellow', 'preparing' => 'orange', 'delivery_waiting' => 'blue', 'in_delivery' => 'indigo', 'finished' => 'green' } %>
      <% color = state_colors[@order.state] || 'gray' %>
      <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-<%= color %>-100 text-<%= color %>-800">
        <%= @order.state.humanize %>
      </span>
    </div>

    <div class="flex space-x-3">
      <% if @order.may_start_preparing? %>
        <%= link_to transition_admin_order_path(@order, event: :start_preparing), data: { "turbo-method": :patch, "turbo-confirm": "Accept Order ##{@order.id}?" }, class: "inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-orange-600 hover:bg-orange-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-orange-500" do %>
            Accept Order
        <% end %>
      <% end %>
      <% if @order.may_wait_for_delivery? %>
        <%= link_to transition_admin_order_path(@order, event: :wait_for_delivery), data: { "turbo-method": :patch, "turbo-confirm": "Mark Order ##{@order.id} as ready for delivery?" }, class: "inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" do %>
            Ready for Delivery
        <% end %>
      <% end %>
      <% if @order.may_start_delivery? %>
        <%= link_to transition_admin_order_path(@order, event: :start_delivery), data: { "turbo-method": :patch, "turbo-confirm": "Start delivery for Order ##{@order.id}?" }, class: "inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" do %>
            Start Delivery
        <% end %>
      <% end %>
      <% if @order.may_finish? %>
        <%= link_to transition_admin_order_path(@order, event: :finish), data: { "turbo-method": :patch, "turbo-confirm": "Mark Order ##{@order.id} as finished?" }, class: "inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500" do %>
            Mark Finished
        <% end %>
      <% end %>
    </div>
  </div>

  <%# Order Info %>
  <div class="bg-white shadow rounded-lg p-6 mb-6">
    <h2 class="text-lg font-medium text-gray-900 mb-4">Order Information</h2>
    <dl class="grid grid-cols-2 gap-x-6 gap-y-4 sm:grid-cols-4">
      <div>
        <dt class="text-sm font-medium text-gray-500">State</dt>
        <dd class="mt-1 text-sm text-gray-900"><%= @order.state.humanize %></dd>
      </div>
      <div>
        <dt class="text-sm font-medium text-gray-500">Sharing Type</dt>
        <dd class="mt-1 text-sm text-gray-900"><%= @order.sharing_type&.humanize || "Not set" %></dd>
      </div>
      <div>
        <dt class="text-sm font-medium text-gray-500">Created</dt>
        <dd class="mt-1 text-sm text-gray-900"><%= @order.created_at.strftime("%b %d, %Y %H:%M") %></dd>
      </div>
      <div>
        <dt class="text-sm font-medium text-gray-500">Updated</dt>
        <dd class="mt-1 text-sm text-gray-900"><%= @order.updated_at.strftime("%b %d, %Y %H:%M") %></dd>
      </div>
    </dl>
  </div>

  <%# Order Items %>
  <div class="bg-white shadow rounded-lg overflow-hidden mb-6">
    <div class="px-6 py-4 border-b border-gray-200">
      <h2 class="text-lg font-medium text-gray-900">Order Items</h2>
    </div>
    <% if @order_items.any? %>
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Article</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Market</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Price</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Qty</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Subtotal</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Splits</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @order_items.each do |item| %>
            <tr>
              <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900"><%= item.article.title %></td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= item.article.market.name %></td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= number_to_currency(item.price, unit: "RSD ", precision: 2) %></td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= item.quantity %></td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900"><%= number_to_currency(item.price * item.quantity, unit: "RSD ", precision: 2) %></td>
              <td class="px-6 py-4 text-sm text-gray-500">
                <% if item.order_item_splits.any? %>
                  <% item.order_item_splits.each do |split| %>
                    <div><%= split.user.name %>: <%= split.share %></div>
                  <% end %>
                <% else %>
                  <span class="text-gray-400">No splits</span>
                <% end %>
              </td>
            </tr>
          <% end %>
          <tr class="bg-gray-50">
            <td class="px-6 py-4 whitespace-nowrap text-sm font-bold text-gray-900" colspan="4">Total</td>
            <td class="px-6 py-4 whitespace-nowrap text-sm font-bold text-gray-900">
              <%= number_to_currency(@order_items.sum { |i| i.price * i.quantity }, unit: "RSD ", precision: 2) %>
            </td>
            <td></td>
          </tr>
        </tbody>
      </table>
    <% else %>
      <div class="px-6 py-4 text-sm text-gray-500">No items in this order.</div>
    <% end %>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <%# Participants %>
    <div class="bg-white shadow rounded-lg overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-200">
        <h2 class="text-lg font-medium text-gray-900">Participants (<%= @order.users.size %>)</h2>
      </div>
      <% if @order.users.any? %>
        <ul class="divide-y divide-gray-200">
          <% @order.users.each do |user| %>
            <li class="px-6 py-3 flex items-center justify-between">
              <div class="flex items-center space-x-3">
                <div class="h-8 w-8 rounded-full bg-indigo-100 flex items-center justify-center">
                  <span class="text-indigo-700 text-sm font-medium"><%= user.name[0].upcase %></span>
                </div>
                <div>
                  <div class="text-sm font-medium text-gray-900"><%= user.name %></div>
                  <div class="text-xs text-gray-500"><%= user.email %></div>
                </div>
              </div>
              <% if @order.user_approved?(user) %>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">Approved</span>
              <% else %>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">Pending</span>
              <% end %>
            </li>
          <% end %>
        </ul>
      <% else %>
        <div class="px-6 py-4 text-sm text-gray-500">No participants.</div>
      <% end %>
    </div>

    <%# Payments %>
    <div class="bg-white shadow rounded-lg overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-200 flex items-center justify-between">
        <h2 class="text-lg font-medium text-gray-900">Payments (<%= @payments.size %>)</h2>
        <% if @order.fully_paid? %>
          <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-green-100 text-green-800">Fully Paid</span>
        <% else %>
          <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-red-100 text-red-800">
            Paid <%= number_to_currency(@order.total_paid, unit: "RSD ", precision: 2) %> / <%= number_to_currency(@order.total, unit: "RSD ", precision: 2) %>
          </span>
        <% end %>
      </div>
      <% if @payments.any? %>
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">User</th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Amount</th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Comment</th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Date</th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-200">
            <% @payments.each do |payment| %>
              <tr>
                <td class="px-6 py-3 whitespace-nowrap text-sm text-gray-900"><%= payment.user.name %></td>
                <td class="px-6 py-3 whitespace-nowrap text-sm text-gray-900"><%= number_to_currency(payment.amount, unit: "RSD ", precision: 2) %></td>
                <td class="px-6 py-3 text-sm text-gray-500"><%= payment.comment || "—" %></td>
                <td class="px-6 py-3 whitespace-nowrap text-sm text-gray-500"><%= payment.created_at.strftime("%b %d, %Y %H:%M") %></td>
                <td class="px-6 py-3 whitespace-nowrap text-sm">
                  <% if payment.confirmed? %>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">Confirmed</span>
                  <% else %>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">Pending</span>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% else %>
        <div class="px-6 py-4 text-sm text-gray-500">No payments recorded.</div>
      <% end %>
    </div>
  </div>
</div>
