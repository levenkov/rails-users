<%= form_with(model: [:admin, @market, article], local: true, html: { multipart: true }, class: "space-y-6") do |form| %>
  <% if article.errors.any? %>
    <div class="rounded-lg bg-red-50 p-4 border border-red-200">
      <div class="flex">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
          </svg>
        </div>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-red-800">
            <%= pluralize(article.errors.count, "error") %> prohibited this article from being saved:
          </h3>
          <div class="mt-2 text-sm text-red-700">
            <ul class="list-disc pl-5 space-y-1">
              <% article.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <div>
    <%= form.label :title, "Title:", class: "block text-sm font-medium text-gray-700" %>
    <div class="mt-1">
      <%= form.text_field :title, class: "w-full rounded-md border border-gray-300 px-3 py-2 text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
    </div>
  </div>

  <div>
    <%= form.label :description, "Description:", class: "block text-sm font-medium text-gray-700" %>
    <div class="mt-1">
      <%= form.text_area :description, rows: 4, class: "w-full rounded-md border border-gray-300 px-3 py-2 text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
    </div>
  </div>

  <div>
    <%= form.label :stock, "Stock:", class: "block text-sm font-medium text-gray-700" %>
    <div class="mt-1">
      <%= form.number_field :stock, min: 0, class: "w-full rounded-md border border-gray-300 px-3 py-2 text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
    </div>
  </div>

  <div>
    <label class="block text-sm font-medium text-gray-700 mb-2">Variants</label>
    <div id="variants-container" class="space-y-2">
      <%= form.fields_for :article_variants do |vf| %>
        <div class="flex items-center gap-3 variant-row">
          <%= vf.hidden_field :id %>
          <%= vf.text_field :name, placeholder: "Name (e.g. M, L, XXL)", class: "w-1/2 rounded-md border border-gray-300 px-3 py-2 text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
          <%= vf.number_field :price, step: "0.01", min: 0, placeholder: "Price (RSD)", class: "w-1/3 rounded-md border border-gray-300 px-3 py-2 text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
          <label class="flex items-center text-sm text-red-600 cursor-pointer">
            <%= vf.check_box :_destroy, class: "mr-1" %> Remove
          </label>
        </div>
      <% end %>
    </div>
    <template id="variant-template">
      <div class="flex items-center gap-3 variant-row">
        <input type="text" name="article[article_variants_attributes][NEW_IDX][name]" placeholder="Name (e.g. M, L, XXL)" class="w-1/2 rounded-md border border-gray-300 px-3 py-2 text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500">
        <input type="number" name="article[article_variants_attributes][NEW_IDX][price]" step="0.01" min="0" placeholder="Price (RSD)" class="w-1/3 rounded-md border border-gray-300 px-3 py-2 text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500">
      </div>
    </template>
    <button type="button" onclick="addVariant()" class="mt-2 text-sm text-indigo-600 hover:text-indigo-900">+ Add variant</button>
    <script>
      var variantIdx = <%= article.article_variants.size %>;
      function addVariant() {
        var tpl = document.getElementById('variant-template').content.cloneNode(true);
        tpl.querySelectorAll('input').forEach(function(el) {
          el.name = el.name.replace('NEW_IDX', variantIdx);
        });
        variantIdx++;
        document.getElementById('variants-container').appendChild(tpl);
      }
    </script>
  </div>

  <div class="flex items-center">
    <%= form.check_box :unlimited, class: "h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-gray-300 rounded" %>
    <%= form.label :unlimited, "Unlimited stock", class: "ml-2 block text-sm text-gray-900" %>
  </div>

  <div>
    <%= form.label :photos, "Photos:", class: "block text-sm font-medium text-gray-700" %>
    <div class="mt-1">
      <% if article.persisted? && article.photos.attached? %>
        <div class="mb-3 flex flex-wrap gap-3">
          <% article.photos.each do |photo| %>
            <% if photo.blob.persisted? %>
              <div class="relative">
                <%= image_tag photo, class: "h-16 w-16 rounded object-cover border border-gray-200" %>
              </div>
            <% end %>
          <% end %>
        </div>
      <% end %>
      <%= form.file_field :photos, multiple: true, accept: "image/png,image/jpeg,image/webp", class: "block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-medium file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100" %>
      <p class="mt-1 text-xs text-gray-500">You can select multiple files.</p>
    </div>
  </div>

  <div class="flex justify-end space-x-3">
    <%= link_to "Cancel", admin_market_articles_path(@market), class: "inline-flex justify-center py-2 px-4 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
    <%= form.submit class: "inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 cursor-pointer" %>
  </div>
<% end %>
