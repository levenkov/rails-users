<%= form_with(model: [:admin, market], local: true, html: { multipart: true }, class: "space-y-6") do |form| %>
  <% if market.errors.any? %>
    <div class="rounded-lg bg-red-50 p-4 border border-red-200">
      <div class="flex">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
          </svg>
        </div>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-red-800">
            <%= pluralize(market.errors.count, "error") %> prohibited this market from being saved:
          </h3>
          <div class="mt-2 text-sm text-red-700">
            <ul class="list-disc pl-5 space-y-1">
              <% market.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <div>
    <%= form.label :name, "Name:", class: "block text-sm font-medium text-gray-700" %>
    <div class="mt-1">
      <%= form.text_field :name, class: "w-full rounded-md border border-gray-300 px-3 py-2 text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
    </div>
  </div>

  <div>
    <%= form.label :owner_id, "Owner:", class: "block text-sm font-medium text-gray-700" %>
    <div class="mt-1">
      <%= form.collection_select :owner_id, User.order(:name), :id, :name, { prompt: "Select an owner" }, class: "w-full rounded-md border border-gray-300 px-3 py-2 text-gray-900 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
    </div>
  </div>

  <div>
    <%= form.label :logo, "Logo:", class: "block text-sm font-medium text-gray-700" %>
    <div class="mt-1">
      <% if market.persisted? && market.logo.attached? && market.logo.blob.persisted? %>
        <div class="mb-3 flex items-center space-x-4">
          <%= image_tag market.logo, class: "h-16 w-16 rounded object-cover border border-gray-200" %>
          <%= link_to "Remove", edit_admin_market_path(market, market: { logo: "" }), data: { "turbo-method": :patch, "turbo-confirm": "Remove current logo?" }, class: "text-sm text-red-600 hover:text-red-900" %>
        </div>
      <% end %>
      <%= form.file_field :logo, accept: "image/png,image/jpeg,image/webp", class: "block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-medium file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100" %>
    </div>
  </div>

  <div>
    <%= form.label :photos, "Photos:", class: "block text-sm font-medium text-gray-700" %>
    <div class="mt-1">
      <% if market.persisted? && market.photos.attached? %>
        <div class="mb-3 flex flex-wrap gap-3">
          <% market.photos.each do |photo| %>
            <% if photo.blob.persisted? %>
              <div class="relative">
                <%= image_tag photo, class: "h-16 w-16 rounded object-cover border border-gray-200" %>
              </div>
            <% end %>
          <% end %>
        </div>
      <% end %>
      <%= form.file_field :photos, multiple: true, accept: "image/png,image/jpeg,image/webp", class: "block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-medium file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100" %>
      <p class="mt-1 text-xs text-gray-500">You can select multiple files.</p>
    </div>
  </div>

  <div class="flex justify-end space-x-3">
    <%= link_to "Cancel", admin_markets_path, class: "inline-flex justify-center py-2 px-4 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
    <%= form.submit class: "inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 cursor-pointer" %>
  </div>
<% end %>
