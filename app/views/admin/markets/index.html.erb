<div class="py-6 px-8">
  <div class="mb-8 flex items-center justify-between" style="max-width: 1200px;">
    <h1 class="text-3xl font-bold text-gray-900">Markets</h1>
    <%= link_to "New Market", new_admin_market_path, class: "inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
  </div>

  <% if @markets.any? %>
    <div class="bg-white shadow rounded-lg overflow-hidden" style="max-width: 1200px;">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">ID</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Name</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Owner</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Articles</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Created</th>
            <th scope="col" class="px-6 py-3 tracking-wider"></th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @markets.each do |market| %>
            <tr class="hover:bg-gray-50 group">
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900"><%= market.id %></td>
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="flex items-center">
                  <% if market.logo.attached? && market.logo.blob.persisted? %>
                    <%= image_tag market.logo, class: "h-8 w-8 rounded object-cover mr-3" %>
                  <% else %>
                    <div class="h-8 w-8 rounded bg-indigo-100 flex items-center justify-center mr-3">
                      <svg class="h-4 w-4 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z" />
                      </svg>
                    </div>
                  <% end %>
                  <div class="text-sm font-medium text-gray-900"><%= market.name %></div>
                </div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900"><%= market.owner.name %></td>
              <td class="px-6 py-4 whitespace-nowrap">
                <%= link_to admin_market_articles_path(market), class: "text-sm text-indigo-600 hover:text-indigo-900" do %>
                  <%= market.articles.size %>
                <% end %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= market.created_at.strftime("%b %d, %Y") %></td>
              <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium space-x-3">
                <%= link_to "Edit", edit_admin_market_path(market), class: "text-indigo-600 hover:text-indigo-900" %>
                <%= link_to "Delete", admin_market_path(market), data: { "turbo-method": :delete, "turbo-confirm": "Are you sure you want to delete #{market.name}?" }, class: "text-red-600 hover:text-red-900" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <div class="mt-6">
      <%= paginate @markets %>
    </div>
  <% else %>
    <div class="bg-white shadow rounded-lg p-6" style="max-width: 1200px;">
      <div class="text-center">
        <h3 class="mt-2 text-sm font-medium text-gray-900">No markets</h3>
        <p class="mt-1 text-sm text-gray-500">Get started by creating a new market.</p>
      </div>
    </div>
  <% end %>
</div>
