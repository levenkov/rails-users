<% if @refresh_token.present? %>
  <div style="background-color: #F0FDF4; padding: 15px; border-radius: 8px; margin-bottom: 20px; border: 1px solid #BBF7D0; color: #166534;">
    <strong>Google refresh token:</strong>
    *****<%= @refresh_token[-4..-1] %>
  </div>
<% else %>
  <div style="background-color: #FFFBEB; padding: 15px; border-radius: 8px; margin-bottom: 20px; border: 1px solid #FDE68A; color: #92400E;">
    <p>Refresh token not configured. You need to get a token to send emails.</p>
  </div>

  <%= link_to "Get token",
      authorize_admin_mail_setup_index_path,
      style: "display: inline-block; padding: 10px 20px; background: #4F46E5; color: white; text-decoration: none; border-radius: 6px; font-weight: 600;" %>
<% end %>
