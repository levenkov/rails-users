<div class="py-6 px-8">
  <div style="max-width: 1200px;">
    <h1 class="text-3xl font-bold text-gray-900 mb-8">Gmail Setup</h1>

  <% if @client_id.nil? || @client_secret.nil? %>
    <%= render 'credentials_not_configured' %>
  <% else %>
    <%= render 'refresh_token_status' %>
    <%= render 'current_settings' %>

    <% if @refresh_token.present? && @from_email.present? %>
      <% if @from_email.nil? %>
        <%= render 'from_email_missing' %>
      <% else %>
        <%= render 'test_email_form' %>
      <% end %>
    <% end %>
  <% end %>
  </div>
</div>
