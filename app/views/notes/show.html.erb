<div class="max-w-3xl mx-auto px-4 py-6">
  <div class="flex items-center justify-between mb-6">
    <%= link_to notes_path, class: "inline-flex items-center text-sm text-gray-500 hover:text-gray-700" do %>
      <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
      Back
    <% end %>
    <%= link_to "Delete", note_path(@note), data: { turbo_method: :delete, turbo_confirm: "Delete this note?" },
        class: "text-sm text-red-500 hover:text-red-700" %>
  </div>

  <div class="bg-white border border-gray-200 rounded-lg p-6 shadow-sm">
    <%= form_with model: @note, class: "space-y-4" do |f| %>
      <%= f.text_field :title,
          placeholder: "Title",
          class: "w-full text-xl font-semibold border-0 border-b border-transparent focus:border-gray-300 focus:ring-0 px-0 py-1 placeholder-gray-400" %>

      <%= f.text_area :body,
          placeholder: "Take a note...",
          rows: 6,
          class: "w-full text-sm border-0 focus:ring-0 px-0 py-1 placeholder-gray-400 resize-none" %>

      <div>
        <label class="block text-xs font-medium text-gray-500 mb-1">Tags (comma-separated)</label>
        <%= f.text_field :tag_names,
            value: @note.note_tags.pluck(:name).join(", "),
            placeholder: "work, ideas, urgent",
            class: "w-full text-sm border border-gray-200 rounded-md px-3 py-1.5 focus:ring-1 focus:ring-yellow-400 focus:border-yellow-400" %>
      </div>

      <div class="flex justify-end">
        <%= f.submit "Save", class: "px-4 py-2 text-sm font-medium text-white bg-yellow-500 rounded-lg hover:bg-yellow-600 cursor-pointer" %>
      </div>
    <% end %>

    <%# Checkpoints section %>
    <div class="mt-6 border-t border-gray-100 pt-4">
      <h4 class="text-sm font-semibold text-gray-700 mb-3">Checkpoints</h4>

      <div id="checkpoints">
        <%= render partial: "notes/point", collection: @note.root_points, as: :point, locals: { depth: 0 } %>
      </div>

      <%# Add new checkpoint %>
      <%= form_with model: [@note, NotePoint.new], class: "flex items-center gap-2 mt-3" do |f| %>
        <%= f.text_field :text, placeholder: "Add a checkpoint...",
            class: "flex-grow text-sm border border-gray-200 rounded-md px-3 py-1.5 focus:ring-1 focus:ring-yellow-400 focus:border-yellow-400" %>
        <%= f.submit "+", class: "px-3 py-1.5 text-sm font-medium text-white bg-gray-400 rounded-md hover:bg-gray-500 cursor-pointer" %>
      <% end %>
    </div>
  </div>
</div>
