<% carts = local_assigns.fetch(:carts, user_carts) %>
<% selected_id = local_assigns.fetch(:selected_cart_id, nil) %>
<% show_link = local_assigns.fetch(:show_cart_link, false) %>
<% market = local_assigns[:market] %>
<div class="mb-6">
  <label class="block text-xs font-medium text-gray-500 uppercase tracking-wider mb-1">Cart</label>
  <div class="flex gap-2">
    <% if market %>
      <select onchange="Turbo.visit('<%= market_path(market) %>' + (this.value === 'new' ? '?new_cart=1' : '?cart_id=' + this.value))"
              class="block w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-sm text-gray-900 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500">
        <% carts.each do |c| %>
          <option value="<%= c.id %>" <%= 'selected' if c.id == selected_id %>>
            <%= c.owner_id == current_user.id ? 'My Cart' : "#{c.owner.name}'s Cart" %> (<%= c.cart_items.sum(&:quantity) %> items)
          </option>
        <% end %>
        <option value="new" <%= 'selected' unless selected_id %>>New cart</option>
      </select>
    <% else %>
      <select onchange="Turbo.visit('/carts/' + this.value)"
              class="block w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-sm text-gray-900 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500">
        <% if carts.empty? %>
          <option>No carts</option>
        <% else %>
          <% carts.each do |c| %>
            <option value="<%= c.id %>" <%= 'selected' if c.id == selected_id %>>
              <%= c.owner_id == current_user.id ? 'My Cart' : "#{c.owner.name}'s Cart" %> — <%= c.market.name %> (<%= c.cart_items.sum(&:quantity) %> items)
            </option>
          <% end %>
        <% end %>
      </select>
    <% end %>
    <% if show_link && selected_id %>
      <%= link_to "View", cart_path(selected_id), class: "flex-shrink-0 py-2 px-4 rounded-md text-sm font-medium text-indigo-600 border border-indigo-300 hover:bg-indigo-50" %>
    <% end %>
  </div>
</div>
