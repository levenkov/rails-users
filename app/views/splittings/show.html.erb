<div class="min-h-screen bg-gray-50 py-8 px-4 sm:px-6 lg:px-8">
  <div class="max-w-4xl mx-auto">
    <%= render 'shared/navigation' %>

    <div class="bg-white shadow rounded-lg overflow-hidden">
      <div class="px-6 py-6 space-y-4">
        <div class="grid grid-cols-3 gap-6">
          <div>
            <dt class="text-sm font-medium text-gray-500">State</dt>
            <dd class="mt-1">
              <% badge_color = case @order.state
                 when "submitted" then "bg-yellow-100 text-yellow-800"
                 when "preparing" then "bg-orange-100 text-orange-800"
                 when "delivery_waiting" then "bg-purple-100 text-purple-800"
                 else "bg-gray-100 text-gray-800"
                 end %>
              <span class="inline-flex px-2 py-1 text-xs font-semibold rounded-full <%= badge_color %>">
                <%= @order.state.humanize %>
              </span>
            </dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-gray-500">Created</dt>
            <dd class="mt-1 text-sm text-gray-900"><%= @order.created_at.strftime("%b %d, %Y %H:%M") %></dd>
          </div>
        </div>
      </div>
    </div>

    <div class="mt-6">
      <div id="split-editor-root" data-order-id="<%= @order.id %>" data-current-user-id="<%= current_user.id %>"></div>
    </div>
  </div>
</div>
