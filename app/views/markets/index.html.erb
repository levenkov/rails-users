<div class="min-h-screen bg-gray-50 py-8 px-4 sm:px-6 lg:px-8">
  <div class="max-w-5xl mx-auto">
    <%= render 'shared/navigation' %>

    <% if @markets.any? %>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <% @markets.each do |market| %>
          <%= link_to market_path(market), class: "bg-white rounded-lg shadow hover:shadow-md transition-shadow overflow-hidden cursor-pointer block" do %>
            <% if market.photos.any? %>
              <div class="relative aspect-[16/9] overflow-hidden" data-controller="carousel" data-carousel-index-value="0">
                <% market.photos.each_with_index do |photo, i| %>
                  <%= image_tag photo, class: "absolute inset-0 w-full h-full object-cover transition-opacity duration-300 #{i == 0 ? 'opacity-100' : 'opacity-0'}", data: { carousel_target: "slide" } %>
                <% end %>
                <% if market.photos.size > 1 %>
                  <button class="absolute left-2 top-1/2 -translate-y-1/2 w-8 h-8 rounded-full bg-white/80 hover:bg-white flex items-center justify-center shadow text-gray-700" data-action="carousel#prev">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                  </button>
                  <button class="absolute right-2 top-1/2 -translate-y-1/2 w-8 h-8 rounded-full bg-white/80 hover:bg-white flex items-center justify-center shadow text-gray-700" data-action="carousel#next">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                  </button>
                  <div class="absolute bottom-2 left-1/2 -translate-x-1/2 flex gap-1.5">
                    <% market.photos.size.times do |i| %>
                      <span class="w-1.5 h-1.5 rounded-full transition-colors duration-300 <%= i == 0 ? 'bg-white' : 'bg-white/50' %>" data-carousel-target="dot"></span>
                    <% end %>
                  </div>
                <% end %>
              </div>
            <% else %>
              <div class="aspect-[16/9] bg-gray-100 flex items-center justify-center">
                <svg class="w-12 h-12 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                </svg>
              </div>
            <% end %>
            <div class="p-5">
              <h2 class="text-lg font-bold text-gray-900"><%= market.name %></h2>
              <p class="mt-1 text-sm text-gray-500"><%= pluralize(market.articles.size, "article") %></p>
              <p class="mt-1 text-xs text-gray-400">by <%= market.owner.name %></p>
            </div>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-20">
        <p class="text-lg text-gray-500">No markets yet</p>
      </div>
    <% end %>
  </div>
</div>

<script>
(function() {
  function initCarousels() {
    document.querySelectorAll('[data-controller="carousel"]').forEach(function(el) {
      var slides = el.querySelectorAll('[data-carousel-target="slide"]');
      var dots = el.querySelectorAll('[data-carousel-target="dot"]');
      var index = 0;

      function show(i) {
        index = (i + slides.length) % slides.length;
        slides.forEach(function(s, j) {
          s.style.opacity = j === index ? '1' : '0';
        });
        dots.forEach(function(d, j) {
          d.style.backgroundColor = j === index ? 'white' : 'rgba(255,255,255,0.5)';
        });
      }

      el.querySelector('[data-action="carousel#prev"]')?.addEventListener('click', function(e) { e.preventDefault(); e.stopPropagation(); show(index - 1); });
      el.querySelector('[data-action="carousel#next"]')?.addEventListener('click', function(e) { e.preventDefault(); e.stopPropagation(); show(index + 1); });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCarousels);
  } else {
    initCarousels();
  }
  document.addEventListener('turbo:load', initCarousels);
})();
</script>
