<div class="min-h-screen bg-gray-50 py-8 px-4 sm:px-6 lg:px-8">
  <div class="max-w-4xl mx-auto">
    <%= render 'shared/navigation' %>

    <div class="bg-white rounded-lg shadow overflow-hidden">
      <% if @market.photos.any? %>
        <div class="relative aspect-[16/9] overflow-hidden" data-controller="carousel" data-carousel-index-value="0">
          <% @market.photos.each_with_index do |photo, i| %>
            <%= image_tag photo, class: "absolute inset-0 w-full h-full object-cover transition-opacity duration-300 #{i == 0 ? 'opacity-100' : 'opacity-0'}", data: { carousel_target: "slide" } %>
          <% end %>
          <% if @market.photos.size > 1 %>
            <button class="absolute left-3 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-white/80 hover:bg-white flex items-center justify-center shadow text-gray-700" data-action="carousel#prev">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
            </button>
            <button class="absolute right-3 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-white/80 hover:bg-white flex items-center justify-center shadow text-gray-700" data-action="carousel#next">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </button>
            <div class="absolute bottom-3 left-1/2 -translate-x-1/2 flex gap-2">
              <% @market.photos.size.times do |i| %>
                <span class="w-2 h-2 rounded-full transition-colors duration-300 <%= i == 0 ? 'bg-white' : 'bg-white/50' %>" data-carousel-target="dot"></span>
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>

      <div class="p-6">
        <h1 class="text-2xl font-bold text-gray-900"><%= @market.name %></h1>
        <p class="mt-1 text-sm text-gray-500">by <%= @market.owner.name %></p>
      </div>
    </div>

    <div class="mt-8">
      <%= render 'shared/cart_selector', carts: @market_carts, selected_cart_id: @selected_cart_id, new_cart: @new_cart.presence, market: @market, show_cart_link: true %>
    </div>

    <% if @market.articles.any? %>
      <div class="mb-4">
        <h2 class="text-lg font-semibold text-gray-900">Articles</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <% @market.articles.each do |article| %>
          <div class="bg-white rounded-lg shadow overflow-hidden flex">
            <% if article.photos.any? %>
              <div class="w-28 h-28 flex-shrink-0">
                <%= image_tag article.photos.first, class: "w-full h-full object-cover" %>
              </div>
            <% end %>
            <div class="p-4 flex flex-col justify-center flex-1">
              <h3 class="font-medium text-gray-900"><%= article.title %></h3>
              <% if article.article_variants.any? %>
                <% min, max = article.price_range %>
                <p class="mt-1 text-sm font-semibold text-indigo-600">
                  <% if min == max %>
                    <%= number_with_delimiter(min.to_i) %> RSD
                  <% else %>
                    <%= number_with_delimiter(min.to_i) %> – <%= number_with_delimiter(max.to_i) %> RSD
                  <% end %>
                </p>
              <% end %>
              <% if article.description.present? %>
                <p class="mt-1 text-xs text-gray-500 line-clamp-2"><%= article.description %></p>
              <% end %>
              <% if article.unlimited? || article.stock > 0 %>
                <% if article.single_variant? %>
                  <% qty = @cart_quantities[article.default_variant.id] || 0 %>
                  <% if qty > 0 %>
                    <div class="mt-2 self-start inline-flex items-center rounded-md border border-gray-300 overflow-hidden">
                      <%= button_to remove_carts_path(article_variant_id: article.default_variant.id, cart_id: @selected_cart_id, new_cart: @new_cart.presence), class: "py-1 px-2 text-xs font-medium text-gray-700 hover:bg-gray-100 cursor-pointer" do %>
                        −
                      <% end %>
                      <span class="py-1 px-3 text-xs font-semibold text-gray-900 border-x border-gray-300"><%= qty %></span>
                      <%= button_to add_carts_path(article_variant_id: article.default_variant.id, cart_id: @selected_cart_id, new_cart: @new_cart.presence), class: "py-1 px-2 text-xs font-medium text-gray-700 hover:bg-gray-100 cursor-pointer" do %>
                        +
                      <% end %>
                    </div>
                  <% else %>
                    <%= button_to "Add to Cart", add_carts_path(article_variant_id: article.default_variant.id, cart_id: @selected_cart_id, new_cart: @new_cart.presence), class: "mt-2 py-1 px-3 rounded-md text-xs font-medium text-white bg-indigo-600 hover:bg-indigo-700 cursor-pointer" %>
                  <% end %>
                <% else %>
                  <div class="mt-2 flex flex-wrap gap-2">
                    <% article.article_variants.each do |variant| %>
                      <% qty = @cart_quantities[variant.id] || 0 %>
                      <% if qty > 0 %>
                        <div class="inline-flex items-center rounded-md border border-gray-300 overflow-hidden">
                          <%= button_to remove_carts_path(article_variant_id: variant.id, cart_id: @selected_cart_id, new_cart: @new_cart.presence), class: "py-1 px-2 text-xs font-medium text-gray-700 hover:bg-gray-100 cursor-pointer" do %>
                            −
                          <% end %>
                          <span class="py-1 px-2 text-xs font-semibold text-gray-900 border-x border-gray-300"><%= variant.name %> – <%= number_with_delimiter(variant.price.to_i) %>: ×<%= qty %></span>
                          <%= button_to add_carts_path(article_variant_id: variant.id, cart_id: @selected_cart_id, new_cart: @new_cart.presence), class: "py-1 px-2 text-xs font-medium text-gray-700 hover:bg-gray-100 cursor-pointer" do %>
                            +
                          <% end %>
                        </div>
                      <% else %>
                        <%= button_to "#{variant.name} – #{number_with_delimiter(variant.price.to_i)}", add_carts_path(article_variant_id: variant.id, cart_id: @selected_cart_id, new_cart: @new_cart.presence), class: "py-1 px-2 rounded-md text-xs font-medium text-white bg-indigo-600 hover:bg-indigo-700 cursor-pointer" %>
                      <% end %>
                    <% end %>
                  </div>
                <% end %>
              <% else %>
                <span class="mt-1 inline-block text-xs text-red-500">Unavailable</span>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-12">
        <p class="text-gray-500">No articles yet</p>
      </div>
    <% end %>
  </div>
</div>

<script>
(function() {
  function initCarousels() {
    document.querySelectorAll('[data-controller="carousel"]').forEach(function(el) {
      var slides = el.querySelectorAll('[data-carousel-target="slide"]');
      var dots = el.querySelectorAll('[data-carousel-target="dot"]');
      var index = 0;

      function show(i) {
        index = (i + slides.length) % slides.length;
        slides.forEach(function(s, j) {
          s.style.opacity = j === index ? '1' : '0';
        });
        dots.forEach(function(d, j) {
          d.style.backgroundColor = j === index ? 'white' : 'rgba(255,255,255,0.5)';
        });
      }

      el.querySelector('[data-action="carousel#prev"]')?.addEventListener('click', function() { show(index - 1); });
      el.querySelector('[data-action="carousel#next"]')?.addEventListener('click', function() { show(index + 1); });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCarousels);
  } else {
    initCarousels();
  }
  document.addEventListener('turbo:load', initCarousels);
})();
</script>
