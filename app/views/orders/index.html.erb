<div class="min-h-screen bg-gray-50 py-8 px-4 sm:px-6 lg:px-8">
  <div class="max-w-4xl mx-auto">
    <%= render 'shared/navigation' %>

    <% if @orders.any? %>
      <div class="bg-white shadow rounded-lg overflow-hidden">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">ID</th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Sharing Type</th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">State</th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Items</th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Created</th>
              <th scope="col" class="px-6 py-3 tracking-wider"></th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-200">
            <% @orders.each do |order| %>
              <tr class="hover:bg-gray-50">
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900"><%= order.id %></td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900"><%= order.sharing_type&.humanize || "Not set" %></td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <% badge_color = case order.state
                     when "submitted" then "bg-yellow-100 text-yellow-800"
                     when "preparing" then "bg-orange-100 text-orange-800"
                     when "delivery_waiting" then "bg-purple-100 text-purple-800"
                     when "in_delivery" then "bg-orange-100 text-orange-800"
                     when "finished" then "bg-green-100 text-green-800"
                     else "bg-gray-100 text-gray-800"
                     end %>
                  <span class="inline-flex px-2 py-1 text-xs font-semibold rounded-full <%= badge_color %>">
                    <%= order.state.humanize %>
                  </span>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900"><%= order.order_items.size %></td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= order.created_at.strftime("%b %d, %Y") %></td>
                <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                  <%= link_to "View", order_path(order), class: "text-indigo-600 hover:text-indigo-900" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="bg-white shadow rounded-lg p-6">
        <div class="text-center">
          <h3 class="mt-2 text-sm font-medium text-gray-900">No orders yet</h3>
          <p class="mt-1 text-sm text-gray-500">Get started by creating a new order.</p>
        </div>
      </div>
    <% end %>
  </div>
</div>
