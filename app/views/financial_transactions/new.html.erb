<div class="min-h-screen bg-gray-50 py-8 px-4 sm:px-6 lg:px-8">
  <div class="max-w-lg mx-auto">
    <%= render 'shared/navigation' %>

    <div class="mb-6">
      <%= link_to "← Back to Profile", users_me_path, class: "text-indigo-600 hover:text-indigo-900 text-sm" %>
    </div>

    <div class="bg-white shadow rounded-lg overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-200">
        <h1 class="text-lg font-semibold text-gray-900">Record Peer-to-Peer Payment</h1>
        <p class="mt-1 text-sm text-gray-500">Record a direct payment you made to another user.</p>
      </div>

      <div class="px-6 py-6">
        <%= form_with model: @transaction, url: financial_transactions_path do |f| %>
          <% if @transaction.errors.any? %>
            <div class="mb-4 p-3 rounded-md bg-red-50 border border-red-200">
              <% @transaction.errors.full_messages.each do |msg| %>
                <p class="text-sm text-red-700"><%= msg %></p>
              <% end %>
            </div>
          <% end %>

          <div class="space-y-4">
            <div>
              <%= f.label :receiver_id, "Pay to", class: "block text-sm font-medium text-gray-700" %>
              <%= f.collection_select :receiver_id, @users, :id, :name, { prompt: "Select user..." },
                class: "mt-1 w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm" %>
            </div>

            <div>
              <%= f.label :amount, "Amount (RSD)", class: "block text-sm font-medium text-gray-700" %>
              <%= f.number_field :amount, step: 0.01, min: 0.01, required: true,
                class: "mt-1 w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm" %>
            </div>

            <div>
              <%= f.label :description, "Description (optional)", class: "block text-sm font-medium text-gray-700" %>
              <%= f.text_field :description,
                class: "mt-1 w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm" %>
            </div>

            <div class="pt-2">
              <%= f.submit "Record Payment",
                class: "w-full inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
